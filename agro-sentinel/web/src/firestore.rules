rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default-deny everything (VULN-13)
    match /{document=**} {
      allow read, write: if false;
    }

    // Greenhouses — authenticated reads only.
    // Writes are performed exclusively by Cloud Functions using the Admin SDK,
    // which bypasses these rules — no direct client writes are permitted.
    match /greenhouses/{sensorId} {
      allow read: if request.auth != null;
      allow write: if false;

      // Thermal scan sub-collection — same policy
      match /thermal_scans/{scanId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
