# ── Firebase Auth (REQUIRED for production login) ─────────────────────────────
# Copy this file to .env and fill in your Firebase project values.
# Find these in Firebase Console → Project settings → Your apps → SDK setup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── GCP Cloud Functions (leave empty to use MOCK mode) ─────────────────────────
# VITE_USE_MOCK=false
# VITE_SENSOR_API_URL=https://us-central1-your-project.cloudfunctions.net
# VITE_AI_FUNCTION_URL=https://us-central1-your-project.cloudfunctions.net/ask-ai
